EXPO_TUNNEL_SUBDOMAIN=financial-risk-scan
EXPO_PACKAGER_HOSTNAME=127.0.0.1
# Leave EXPO_PUBLIC_BACKEND_URL unset so Vercel uses same origin (/api/ai-insights). For local backend, use .env.local with EXPO_PUBLIC_BACKEND_URL=http://127.0.0.1:8000
EXPO_USE_FAST_RESOLVER="1"
METRO_CACHE_ROOT=/app/frontend/.metro-cache